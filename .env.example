# ── Credenciales Firebase ────────────────────────────────────────────────────
#
# Opción A (recomendada): pega el JSON completo de la cuenta de servicio
# como una sola línea (sin saltos de línea).
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"TU_PROYECTO",...}

# Opción B: apunta al archivo JSON descargado desde la consola de Firebase.
# (comenta la opción A si usas esta)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/a/serviceAccountKey.json

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=4173

# ── Entorno ──────────────────────────────────────────────────────────────────
# En "production" el código temporal de recuperación no se muestra en pantalla.
NODE_ENV=development
