rules_version = '2';
// Toda la lógica pasa por el servidor Node.js usando Firebase Admin SDK,
// que ignora estas reglas. Bloqueamos acceso directo desde clientes como
// medida de defensa adicional.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
